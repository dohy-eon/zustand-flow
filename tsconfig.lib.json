{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "outDir": "dist-lib",
    "rootDir": "src",
    "allowImportingTsExtensions": false
  },
  "include": [
    "src/index.ts",
    "src/devtools.tsx",
    "src/lib/**/*.ts",
    "src/react/**/*.ts",
    "src/react/**/*.tsx",
    "src/vite-env.d.ts"
  ],
  "exclude": ["src/main.tsx", "src/App.tsx", "src/store.ts"]
}
